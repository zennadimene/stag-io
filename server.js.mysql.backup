// 📌 ROUTE 11: Delete student CV (PROTECTED)
app.delete('/api/student/cv', protect, async (req, res) => {
    try {
        const userId = req.user.id;
        
        const [result] = await db.execute(
            'UPDATE students SET cv_url = NULL, updated_at = NOW() WHERE user_id = ?',
            [userId]
        );
        
        if (result.affectedRows === 0) {
            return res.status(404).json({
                success: false,
                message: 'Student profile not found'
            });
        }
        
        res.json({
            success: true,
            message: 'CV deleted successfully'
        });
        
    } catch (error) {
        console.error('🔥 Error deleting CV:', error);
        res.status(500).json({
            success: false,
            message: 'Error deleting CV'
        });
    }
});

// 📌 ROUTE 12: Get student dashboard stats (PROTECTED)
