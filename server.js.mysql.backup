// ============================================
// 📌 Download agreement PDF
// ============================================
app.get('/api/student/agreements/:agreementId/download', protect, async (req, res) => {
  try {
    const studentId = req.user.id;
    const agreementId = req.params.agreementId;
    
    console.log(`📥 Downloading agreement ${agreementId} for student ${studentId}`);
    
    // التحقق من أن المستخدم طالب
    if (req.user.user_type !== 'student') {
      return res.status(403).json({ 
        success: false, 
        message: 'Access denied. Students only.' 
      });
    }
    
    // التحقق من أن الاتفاقية موجودة وتخص هذا الطالب
    const [agreements] = await db.execute(
      `SELECT a.*, i.title 
       FROM agreements a
       JOIN internships i ON a.internship_id = i.id
       WHERE a.id = ? AND a.student_id = ?`,
      [agreementId, studentId]
    );
    
    if (agreements.length === 0) {
      return res.status(404).json({ 
        success: false, 
        message: 'Agreement not found' 
      });
    }
    
    const agreement = agreements[0];
    
    // إذا كان هناك ملف PDF حقيقي وليس الملف التجريبي
    if (agreement.pdf_url && !agreement.pdf_url.includes('test_agreement')) {
      const filePath = path.join(__dirname, agreement.pdf_url);
      
      // التحقق من وجود الملف
      if (fs.existsSync(filePath)) {
        return res.download(filePath, `agreement_${agreementId}.pdf`);
      }
    }
    
    // إذا لم يكن هناك ملف حقيقي، أنشئ PDF بسيط
    console.log('📄 Generating PDF for agreement', agreementId);
    
    const PDFDocument = require('pdfkit');
    const doc = new PDFDocument();
    
    res.setHeader('Content-Type', 'application/pdf');
    res.setHeader('Content-Disposition', `attachment; filename=agreement_${agreementId}.pdf`);
    
    doc.pipe(res);
    
    // محتوى PDF
    doc.fontSize(20).text('INTERNSHIP AGREEMENT', { align: 'center' });
    doc.moveDown();
    doc.fontSize(12).text(`Date: ${new Date().toLocaleDateString()}`);
    doc.moveDown();
    doc.text(`This agreement is for internship: ${agreement.title || 'Internship'}`);
    doc.text(`Generated on: ${new Date(agreement.generated_at).toLocaleDateString()}`);
    doc.moveDown();
    doc.text('Terms and Conditions:');
    doc.fontSize(10).text('1. The student agrees to complete the internship period as specified.');
    doc.text('2. The company agrees to provide necessary training and supervision.');
    doc.text('3. Both parties agree to maintain confidentiality.');
    doc.text(`4. The internship will start on ${new Date().toLocaleDateString()}.`);
    doc.moveDown();
    doc.text('Signed: _________________________', { align: 'left' });
    doc.text('Student', { align: 'left' });
    
    doc.end();
    
  } catch (error) {
    console.error('🔥 Error downloading agreement:', error);
    res.status(500).json({ 
      success: false, 
      message: 'Error downloading agreement',
      error: error.message 
    });
  }
});





